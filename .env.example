# Copy this file to `.env` and fill in keys you want to use.
# Do NOT commit your real API keys to version control.

# Choose provider: auto, openai, mock
# - auto: prefer google.genai -> google.generativeai (default)
# - openai: use the openai Python package
# - mock: local mock responses for offline/dev
GENAI_PROVIDER=auto

# Google API key (used when provider is `auto` and a Google SDK is available)
GOOGLE_API_KEY=your-google-api-key-here

# OpenAI API key (used when provider=openai)
OPENAI_API_KEY=sk-...
